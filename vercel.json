{
  "version": 2,
  "buildCommand": "npm run build && php artisan optimize && php artisan migrate --force",
  "devCommand": "npm run dev",
  "outputDirectory": "public",
  "installCommand": "composer install --no-dev && npm install",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
