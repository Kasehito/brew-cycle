{
  "version": 2,
  "buildCommand": "npm run build && php artisan optimize",
  "devCommand": "npm run dev",
  "outputDirectory": "public",
  "installCommand": "composer install --no-dev && npm install",
  "functions": {
    "api/index.php": {
      "runtime": "php-8.3"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
